# Geo-Layer-Viewer API (required)
GEO_LAYER_VIEWER_URL=http://localhost:5000

# CityCatalyst Global API (required)
GLOBAL_API_URL=https://ccglobal.openearth.dev

# Climate TRACE API (optional)
CLIMATE_TRACE_API_URL=https://api.climatetrace.org

# LLM Configuration
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Default city
DEFAULT_CITY_LOCODE=BR POA
