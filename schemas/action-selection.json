{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "action-selection",
  "title": "Action Selection",
  "description": "Schema for action selection component outputs. Captures prioritized actions, scoring rationale, and links to downstream site/technology selection.",
  "type": "object",
  "properties": {
    "cityLocode": { "type": "string", "description": "UN/LOCODE e.g. BR POA" },
    "contextSummary": {
      "type": "object",
      "description": "Key context signals that informed action prioritization",
      "properties": {
        "keyProblems": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Top energy problems identified from context (e.g., grid vulnerability, coal dependency)"
        },
        "existingCommitments": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Existing city/state plans and commitments (e.g., PLAC, TEJ, Pacto Biometano)"
        },
        "funderPriorities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Known funder preferences and eligibility signals"
        },
        "regulatoryEnablers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Policies that enable or constrain action types"
        }
      }
    },
    "scoringCriteria": {
      "type": "array",
      "description": "Criteria used to score and rank actions",
      "items": {
        "type": "object",
        "required": ["id", "label", "weight"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 },
          "description": { "type": "string" }
        }
      }
    },
    "evaluatedActions": {
      "type": "array",
      "description": "All actions evaluated, ranked by composite score",
      "items": {
        "type": "object",
        "required": ["actionId", "name", "compositeScore", "recommendation"],
        "properties": {
          "actionId": { "type": "string", "description": "ID from energy-action-catalog.json" },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "compositeScore": { "type": "number", "minimum": 0, "maximum": 100 },
          "scoreBreakdown": {
            "type": "object",
            "description": "Score per criterion",
            "additionalProperties": { "type": "number" }
          },
          "recommendation": {
            "type": "string",
            "enum": ["priority", "include", "conditional", "defer"],
            "description": "priority=top action, include=should be in portfolio, conditional=depends on unresolved factor, defer=not now"
          },
          "rationale": { "type": "string" },
          "contextSignalsMatched": {
            "type": "object",
            "properties": {
              "supportive": { "type": "array", "items": { "type": "string" } },
              "blocking": { "type": "array", "items": { "type": "string" } }
            }
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Other action IDs this action depends on or pairs with"
          },
          "nextSteps": {
            "type": "array",
            "items": { "type": "string" },
            "description": "What needs to happen to move this action to site selection"
          }
        }
      }
    },
    "actionPortfolio": {
      "type": "object",
      "description": "The recommended portfolio of actions",
      "properties": {
        "priorityActions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Action IDs recommended as priority"
        },
        "complementaryActions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Actions that pair well with priority actions"
        },
        "portfolioRationale": { "type": "string" },
        "estimatedPortfolioImpact": {
          "type": "object",
          "properties": {
            "totalEmissionsReduction": { "type": "string" },
            "totalInvestmentRange": { "type": "string" },
            "totalBeneficiaries": { "type": "string" }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "totalActionsEvaluated": { "type": "integer" },
        "priorityCount": { "type": "integer" },
        "analysisDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      }
    }
  }
}
